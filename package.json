    "color": "^4.2.3",
    "expo": "^50.0.0",
    "expo-av": "~14.0.4",
    "expo-build-properties": "~0.12.0",
    "expo-dev-client": "~3.3.12",
    "expo-haptics": "~12.8.1",
    "expo-keep-awake": "~12.8.2",
    "expo-linear-gradient": "~13.0.2",
    "expo-navigation-bar": "~2.4.1",
    "expo-splash-screen": "~0.26.4",
